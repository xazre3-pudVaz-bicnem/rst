{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }],
  "functions": {
    "api/**/*.ts": { "maxDuration": 300 }
  },
  "crons": [
    { "path": "/api/cron/auto-lead-crawl", "schedule": "0 */2 * * *" }
  ]
}
