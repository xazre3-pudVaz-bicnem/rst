# ============================================================
# RST CRM 環境変数サンプル
# このファイルを .env にコピーして値を設定してください。
#   cp .env.example .env
# ============================================================

# --- フロントエンド（Vite。VITE_ プレフィックス必須） ---
# Supabase プロジェクト設定 > API から取得
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJ...your-anon-key...

# ============================================================
# 以下は Supabase Edge Function 用（フロントには露出しません）
# Supabase Dashboard > Edge Functions > Secrets で設定します。
# ローカルで supabase functions serve する場合は supabase/.env に記載。
# ============================================================
# SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJ...service-role-key...
# ANTHROPIC_API_KEY=sk-ant-...
# SERPER_API_KEY=...your-serper-api-key...
