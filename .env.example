# ============================================================
# RST CRM 環境変数サンプル
# このファイルを .env にコピーして値を設定してください。
#   cp .env.example .env
# ============================================================

# --- フロントエンド（Vite。VITE_ プレフィックス必須） ---
# Supabase プロジェクト設定 > API から取得
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJ...your-anon-key...

# 新規登録を許可するか。false にするとログイン画面の新規登録導線を非表示にします。
# 本番運用では false 推奨（ユーザーは管理者が Supabase で発行）。
VITE_ALLOW_SIGNUP=true

# ============================================================
# Vercel Functions（/api/*）用 サーバー専用シークレット
# フロントには露出しません。Vercel > Settings > Environment Variables に設定。
# ============================================================
# サーバーからSupabaseへ書き込む用（RLSをservice roleでバイパス）
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...service-role-key...

# Google Places API (New) のキー。★VITE_ は付けない（フロント露出禁止）★
GOOGLE_MAPS_API_KEY=AIza...your-server-key...

# Vercel Cron 保護用シークレット（毎朝の自動実行 /api/cron/auto-leads）
CRON_SECRET=任意の長いランダム文字列

# 管理API保護用（任意。未設定なら CRON_SECRET を流用）。
# 画面からはログインJWTで認可するため通常は不要。CLI/疎通確認で X-Admin-Secret を使う場合に設定。
ADMIN_SECRET=任意の長いランダム文字列

# ============================================================
# CLIセットアップ（npm run setup:regional-media）用 — ローカル/Claude Codeのみ
# ============================================================
# Postgres 直結URL（列追加などDDLをCLIから自動適用するために使用）。
# Supabase > Project Settings > Database > Connection string > URI をそのまま貼り付け。
# 例: postgresql://postgres:[PASSWORD]@db.xxxxxxxx.supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.xxxxxxxx.supabase.co:5432/postgres

# API疎通確認（npm run check:regional-media-api）の既定URL（任意。引数でも指定可）
RST_BASE_URL=https://your-app.vercel.app

# ============================================================
# Instagram Web検索（Meta API不使用・公開Web検索＋Anthropic判定）
# ============================================================
# 検索API（どちらか一方でOK。Serper優先）
SERPER_API_KEY=...your-serper-api-key...
# BING_SEARCH_API_KEY=...your-bing-key...
# 検索結果から新店判定（未設定ならルールベースのフォールバック判定）
ANTHROPIC_API_KEY=sk-ant-...
